#!/bin/bash
# NIOMI вҖ” The Black Hat вҖ” one-line installer
# curl -sL https://mrbumchinz.github.io/Uconsole---NIOMI/install | sudo bash

set -e

GREEN='\033[0;32m'
CYAN='\033[0;36m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

err() { echo -e "${RED}[error]${NC} $1" >&2; exit 1; }
warn() { echo -e "${YELLOW}[warn]${NC} $1" >&2; }

[ "$(uname)" = "Linux" ] || err "Only Linux is supported (uConsole / Raspberry Pi OS / Debian / Ubuntu)."
command -v git >/dev/null 2>&1 || err "git is required. Install with: sudo apt-get install git"
command -v bash >/dev/null 2>&1 || err "bash is required."

if ! ping -c 1 -W 3 github.com >/dev/null 2>&1 && ! ping -c 1 -W 3 1.1.1.1 >/dev/null 2>&1; then
    err "No internet (cannot reach github.com or 1.1.1.1). Check your network."
fi

TARGET_USER="${SUDO_USER:-$(whoami)}"
TARGET_HOME=$(getent passwd "$TARGET_USER" | cut -d: -f6)
[ -n "$TARGET_HOME" ] || err "Cannot resolve home directory for user '$TARGET_USER'."

INSTALL_DIR="${INSTALL_DIR:-$TARGET_HOME/python/niomi}"
REPO_URL="https://github.com/MrBumChinz/Uconsole---NIOMI.git"
REPO_BRANCH="main"

echo -e "${CYAN}"
echo "  в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—"
echo "  в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
echo "  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
echo "  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
echo "  в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘"
echo "  в•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қ"
echo -e "  ${GREEN}THE BLACK HAT${CYAN} вҖ” Soul Cage Field Operator${NC}"
echo ""
echo "  Install dir: $INSTALL_DIR"
echo "  Target user: $TARGET_USER"
echo ""

echo -e "${GREEN}[1/3]${NC} Cloning repository..."
if [ -d "$INSTALL_DIR/.git" ]; then
    echo "  Directory exists вҖ” pulling latest..."
    cd "$INSTALL_DIR" || err "Cannot enter $INSTALL_DIR"
    DEFAULT_BRANCH=$(sudo -u "$TARGET_USER" git remote show origin 2>/dev/null \
        | awk '/HEAD branch/ {print $NF}')
    [ -n "$DEFAULT_BRANCH" ] || DEFAULT_BRANCH="$REPO_BRANCH"
    if ! sudo -u "$TARGET_USER" git pull --ff-only origin "$DEFAULT_BRANCH"; then
        warn "git pull failed вҖ” continuing with existing copy"
    fi
elif [ -d "$INSTALL_DIR" ]; then
    err "$INSTALL_DIR exists but is not a git repo. Remove it first or set INSTALL_DIR=..."
else
    mkdir -p "$(dirname "$INSTALL_DIR")"
    chown "$TARGET_USER:$TARGET_USER" "$(dirname "$INSTALL_DIR")" 2>/dev/null || true
    if ! sudo -u "$TARGET_USER" git clone --branch "$REPO_BRANCH" "$REPO_URL" "$INSTALL_DIR"; then
        err "git clone failed вҖ” check internet connection and try again"
    fi
    cd "$INSTALL_DIR" || err "Cannot enter $INSTALL_DIR after clone"
fi

echo ""
echo -e "${GREEN}[2/3]${NC} Running setup (this may take a few minutes)..."
if ! bash setup.sh; then
    err "setup.sh failed вҖ” see errors above. Re-run: cd $INSTALL_DIR && sudo bash setup.sh"
fi

echo ""
echo -e "${GREEN}[3/3]${NC} Creating desktop launcher..."
DESKTOP_DIR="$TARGET_HOME/Desktop"
if [ -d "$DESKTOP_DIR" ]; then
    DESKTOP_FILE="$DESKTOP_DIR/niomi.desktop"
    cat > "$DESKTOP_FILE" << DESKTOP
[Desktop Entry]
Name=NIOMI
Comment=The Black Hat вҖ” Soul Cage Field Operator
Exec=lxterminal --title="NIOMI" -e bash -c "cd $INSTALL_DIR && sudo -E ./run.sh; read -p 'Press Enter to close...'"
Terminal=false
Type=Application
Categories=Game;Security;
Icon=$INSTALL_DIR/assets/icon.png
DESKTOP
    chmod +x "$DESKTOP_FILE" 2>/dev/null || true
    chown "$TARGET_USER:$TARGET_USER" "$DESKTOP_FILE" 2>/dev/null || true
    echo "  Created: $DESKTOP_FILE"
else
    warn "No Desktop folder at $DESKTOP_DIR вҖ” skipping launcher"
fi

echo ""
echo -e "${GREEN}в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${NC}"
echo -e "${GREEN}в•‘         Installation complete!              в•‘${NC}"
echo -e "${GREEN}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${NC}"
echo ""
echo -e "  ${CYAN}To start:${NC}  cd $INSTALL_DIR && sudo ./run.sh"
if [ -d "$DESKTOP_DIR" ]; then
    echo -e "  ${CYAN}Desktop:${NC}  Double-click NIOMI on desktop"
fi
echo ""
echo -e "  ${YELLOW}Optional:${NC} edit secrets.conf for Soul Cage API key"
echo -e "           cp secrets.conf.example secrets.conf && nano secrets.conf"
echo -e "           SC_API_KEY=<your-key-from-soulcage.win/territory (Captures tab > API Key)>"
echo ""
echo -e "  ${GREEN}// real hacking is cooler than simulated${NC}"
echo ""
